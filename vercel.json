{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/cron/cleanup-expired",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/match-rating-reminder",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
