generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== KULLANICI ==========
enum UserType {
  INDIVIDUAL  // Bireysel Sporcu
  TRAINER     // Profesyonel Eğitmen
  VENUE       // Mekan / Kurumsal
}

enum UserLevel {
  BEGINNER   // Acemi
  AMATEUR    // Amatör
  SEMI_PRO   // Yarı Profesyonel
  PRO        // Profesyonel
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

// Gizlilik seviyesi — Mesaj, Teklif, Profil görünürlüğü için
enum PrivacyLevel {
  EVERYONE    // Herkes
  FOLLOWERS   // Sadece takipçiler
  NOBODY      // Kimse
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?
  phone        String?
  avatarUrl    String?
  coverUrl     String?   // Kapak fotoğrafı
  bio          String?
  cityId       String?
  city         City?     @relation(fields: [cityId], references: [id])
  districtId   String?
  district     District? @relation(fields: [districtId], references: [id])
  gender       Gender?                          // Cinsiyet
  birthDate    DateTime?                        // Doğum Tarihi
  userType     UserType  @default(INDIVIDUAL)        // Kullanıcı tipi
  userLevel    UserLevel @default(BEGINNER)          // Sporcu seviyesi
  noShowCount  Int       @default(0)                 // Gelmedi sayacı
  warnCount    Int       @default(0)                 // Uyarı sayacı
  isBanned     Boolean   @default(false)             // Geçici kısıtlama
  // Gamification
  currentStreak  Int     @default(0)                 // Günlük seri (aktif gün sayısı)
  longestStreak  Int     @default(0)                 // Rekor seri
  lastActiveDate DateTime?                           // Seri hesabı için son aktif tarih
  totalMatches   Int     @default(0)                 // Cache: toplam maç sayısı
  totalPoints    Int     @default(0)                 // Cache: birikmiş puan
  // Onboarding tercihleri
  preferredTime  String?                             // "morning" | "evening" | "anytime"
  preferredStyle String?                             // "competitive" | "casual" | "both"
  onboardingDone Boolean @default(false)
  isAdmin        Boolean   @default(false)             // Yönetici yetkisi
  // Sosyal Medya Linkleri
  instagram      String?                              // Instagram URL/kullanıcı adı
  tiktok         String?                              // TikTok kullanıcı adı
  facebook       String?                              // Facebook URL
  twitterX       String?                              // X (Twitter) kullanıcı adı
  vk             String?                              // VK URL
  // Gizlilik Ayarları
  whoCanMessage   PrivacyLevel  @default(EVERYONE)   // Bana kim mesaj yazabilir
  whoCanChallenge PrivacyLevel  @default(EVERYONE)   // Bana kim teklif gönderebilir
  profileVisibility PrivacyLevel @default(EVERYONE)  // Profilim kimler tarafından görülebilir
  showOnLeaderboard Boolean     @default(true)       // Liderlik tablosunda göster
  lastSeenAt   DateTime? @default(now())             // Son görülme
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  listings          Listing[]
  responses         Response[]
  matches1          Match[]         @relation("MatchUser1")
  matches2          Match[]         @relation("MatchUser2")
  sports            Sport[]         @relation("UserSports")
  ratingsGiven      Rating[]        @relation("RatingGiver")
  ratingsReceived   Rating[]        @relation("RatingReceiver")
  notifications     Notification[]
  favorites         Favorite[]
  resetTokens       PasswordResetToken[]
  followers         Follow[]        @relation("FollowTarget")
  following         Follow[]        @relation("FollowSource")
  messagesSent      Message[]       @relation("MessageSender")
  messagesReceived  Message[]       @relation("MessageReceiver")
  dirConvsAsUser1   DirectConversation[] @relation("DirConvUser1")
  dirConvsAsUser2   DirectConversation[] @relation("DirConvUser2")
  noShowsReported   NoShowReport[]  @relation("NoShowReporter")
  noShowsReceived   NoShowReport[]  @relation("NoShowReceived")
  trainerProfile    TrainerProfile?
  venueProfile      VenueProfile?
  posts             Post[]
  postLikes         PostLike[]
  postComments      PostComment[]
  stories           Story[]
  storyViews        StoryView[]
  storyHighlights   StoryHighlight[]
  matchesApproved   Match[]         @relation("MatchApprover")
  clubMemberships    UserClubMembership[]
  challengesSent     DirectChallenge[] @relation("ChallengesSent")
  challengesReceived DirectChallenge[] @relation("ChallengesReceived")
  groupMemberships   GroupMembership[]
  groupsCreated      Group[]           @relation("GroupCreator")
  clubsCreated       Club[]            @relation("ClubCreator")
  communityMemberships CommunityMembership[]
  communitiesCreated   Community[]       @relation("CommunityCreator")
  pushSubscriptions    PushSubscription[]
  createdTournaments   Tournament[]      @relation("CreatedTournaments")
  tournamentParticipations TournamentParticipant[] @relation("TournamentParticipations")
  blocksGiven          UserBlock[]       @relation("BlockSource")
  blocksReceived       UserBlock[]       @relation("BlockTarget")
  reportsGiven         UserReport[]      @relation("ReportSource")
  reportsReceived      UserReport[]      @relation("ReportTarget")
}

// ========== SPOR ==========
model Sport {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String?
  listings Listing[]
  venues   Venue[]
  users    User[]    @relation("UserSports")
  clubs       Club[]
  challenges  DirectChallenge[]
  groups      Group[]
  communities Community[]
  tournaments Tournament[]
}

// ========== KONUM ==========
model Country {
  id     String @id @default(cuid())
  name   String @unique
  code   String @unique
  cities City[]
}

model City {
  id        String     @id @default(cuid())
  name      String
  countryId String
  country   Country    @relation(fields: [countryId], references: [id])
  districts District[]
  users     User[]
  clubs       Club[]
  groups      Group[]
  communities Community[]
  listings    Listing[]

  @@unique([name, countryId])
}

model District {
  id       String    @id @default(cuid())
  name     String
  cityId   String
  city     City      @relation(fields: [cityId], references: [id])
  venues   Venue[]
  listings Listing[]
  users    User[]
  challenges DirectChallenge[]

  @@unique([name, cityId])
}

// ========== MEKAN ==========
model Venue {
  id         String    @id @default(cuid())
  name       String
  address    String?
  districtId String
  district   District  @relation(fields: [districtId], references: [id])
  sportId    String?
  sport      Sport?    @relation(fields: [sportId], references: [id])
  listings   Listing[]
  tournaments Tournament[]

  @@unique([name, districtId])
}

// ========== İLAN ==========
enum ListingType {
  RIVAL
  PARTNER
  TRAINER    // Eğitmen ilanı
  EQUIPMENT  // Satılık spor malzemesi
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ListingStatus {
  OPEN
  CLOSED
  MATCHED
  EXPIRED
}

enum AllowedGender {
  ANY
  FEMALE_ONLY
  MALE_ONLY
}

model Listing {
  id              String        @id @default(cuid())
  type            ListingType
  sportId         String
  sport           Sport         @relation(fields: [sportId], references: [id])
  cityId          String?
  city            City?         @relation(fields: [cityId], references: [id])
  districtId      String?
  district        District?     @relation(fields: [districtId], references: [id])
  venueId         String?
  venue           Venue?        @relation(fields: [venueId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  dateTime        DateTime
  level           Level
  description     String?
  status          ListingStatus @default(OPEN)
  maxParticipants Int           @default(2)       // 2=1v1, 3+=grup
  allowedGender   AllowedGender @default(ANY)     // Cinsiyet kısıtı
  isQuick         Boolean       @default(false)   // "Hadi Gel" hızlı ilan
  isUrgent        Boolean       @default(false)   // 30 dakikalık anlık eşleşme talebi
  isAnonymous     Boolean       @default(false)   // Kör maç: profil eşleşmeye kadar gizli
  expiresAt       DateTime?                       // Hızlı/acil ilan bitiş zamanı
  isRecurring     Boolean       @default(false)   // Tekrarlayan etkinlik
  recurringDays   String?                         // "MON,WED,FRI" formatında
  minAge          Int?                            // Başvuru için minimum yaş (opsiyonel)
  maxAge          Int?                            // Başvuru için maksimum yaş (opsiyonel)
  groupId         String?                         // Bağlı grup (opsiyonel)
  group           Group?        @relation(fields: [groupId], references: [id])
  latitude        Float?                          // GPS koordinatı (opsiyonel)
  longitude       Float?                          // GPS koordinatı (opsiyonel)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  responses   Response[]
  match       Match?
  favorites   Favorite[]
  noShows         NoShowReport[]
  trainerProfile  TrainerProfile?
  equipmentDetail EquipmentDetail?

  @@index([status, dateTime])
  @@index([sportId])
  @@index([districtId])
  @@index([userId])
  @@index([status, sportId, dateTime])
  @@index([expiresAt])
  @@index([cityId])
  @@index([type])
}

// ========== KARŞILIK ==========
enum ResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Response {
  id        String         @id @default(cuid())
  listingId String
  listing   Listing        @relation(fields: [listingId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  message   String?
  status    ResponseStatus @default(PENDING)
  createdAt DateTime       @default(now())

  match Match?

  @@unique([listingId, userId])
  @@index([userId])
  @@index([status])
}

// ========== EŞLEŞME ==========
enum MatchStatus {
  SCHEDULED   // Planlandı (henüz yapılmadı)
  ONGOING     // Devam ediyor
  COMPLETED   // Tamamlandı ve doğrulandı
  DISPUTED    // İtiraz var
}

model Match {
  id         String      @id @default(cuid())
  listingId  String      @unique
  listing    Listing     @relation(fields: [listingId], references: [id])
  responseId String      @unique
  response   Response    @relation(fields: [responseId], references: [id])
  user1Id    String
  user1      User        @relation("MatchUser1", fields: [user1Id], references: [id])
  user2Id    String
  user2      User        @relation("MatchUser2", fields: [user2Id], references: [id])
  status     MatchStatus @default(SCHEDULED)
  scheduledAt DateTime?                           // Maç zamanı (listing.dateTime kopyası)
  completedAt DateTime?                           // Tamamlanma zamanı
  // --- Güven Skoru (0-100) ---
  trustScore    Int     @default(0)               // Composite: OTP+Geo+ThirdParty
  // --- Geofencing (Pasif) ---
  lat1          Float?                            // user1 koordinat
  lng1          Float?
  lat2          Float?                            // user2 koordinat
  lng2          Float?
  locationVerifiedAt DateTime?                    // Koordinatlar eşleştiğinde
  // --- Üçüncü Taraf Onayı ---
  approvedById  String?                           // Onaylayan VENUE/TRAINER userId
  approvedBy    User?   @relation("MatchApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
  createdAt     DateTime @default(now())

  ratings      Rating[]
  messages     Message[]
  noShowReports NoShowReport[]
  otps         MatchOtp[]

  @@index([user1Id])
  @@index([user2Id])
  @@index([status])
  @@index([approvedById])
}

// ========== DEĞERLENDİRME ==========
model Rating {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id])
  ratedById   String
  ratedBy     User     @relation("RatingGiver", fields: [ratedById], references: [id])
  ratedUserId String
  ratedUser   User     @relation("RatingReceiver", fields: [ratedUserId], references: [id])
  score       Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([matchId, ratedById])
  @@index([ratedUserId])
}

// ========== BİLDİRİM ==========
enum NotificationType {
  NEW_RESPONSE
  RESPONSE_ACCEPTED
  RESPONSE_REJECTED
  NEW_MATCH
  NEW_RATING
  NEW_FOLLOWER
  FOLLOW_REQUEST       // Takip isteği geldi
  FOLLOW_ACCEPTED      // Takip isteği kabul edildi
  NEW_MESSAGE
  NO_SHOW_WARNING
  NEW_POST_LIKE         // Gönderi beğenildi
  NEW_POST_COMMENT      // Gönderiye yorum yapıldı
  TRAINER_VERIFIED      // Eğitmen profili onaylandı
  MATCH_STATUS_CHANGED  // Maç durumu değişti
  STREAK_MILESTONE      // Seri rekoru kırıldı
  LEVEL_UP              // Seviye atlandı
  MATCH_OTP_REQUESTED   // OTP doğrulama talebi
  VENUE_VERIFIED        // Mekan profili onaylandı
  DIRECT_CHALLENGE      // Doğrudan maç teklifi
  COMMUNITY_JOIN_REQUEST // Topluluk katılma talebi
  COMMUNITY_UPDATE      // Topluluk üyelik güncellemesi
  TOURNAMENT_INVITE     // Turnuvaya davet
  TOURNAMENT_RESULT     // Turnuva sonucu açıklandı
  USER_REPORT           // Admin'e kullanıcı şikayeti
  URGENT_LISTING_NEARBY // Anlık eşleşme talebi yakında
  MATCH_REVEAL          // Kör maç: profil açıldı
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ========== FAVORİLER ==========
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ========== ŞİFRE SIFIRLAMA ==========
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  user      User     @relation(fields: [email], references: [email])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ========== TAKİP ==========
enum FollowStatus {
  PENDING   // İstek bekleniyor
  ACCEPTED  // Kabul edildi
  REJECTED  // Reddedildi
}

model Follow {
  id          String       @id @default(cuid())
  followerId  String       // takip eden
  follower    User         @relation("FollowSource", fields: [followerId], references: [id])
  followingId String       // takip edilen
  following   User         @relation("FollowTarget", fields: [followingId], references: [id])
  status      FollowStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([followingId, status])
}

// ========== NO-SHOW RAPORU ==========
model NoShowReport {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id])
  reporterId String
  reporter   User     @relation("NoShowReporter", fields: [reporterId], references: [id])
  reportedId String
  reported   User     @relation("NoShowReceived", fields: [reportedId], references: [id])
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([matchId, reporterId])
  @@index([reportedId])
  @@index([matchId])
}

// ========== MESAJLAŞMA ==========

/// İki kullanıcı arasındaki direkt sohbet kanalı (eşleşme gerektirmez)
model DirectConversation {
  id        String   @id @default(cuid())
  user1Id   String
  user1     User     @relation("DirConvUser1", fields: [user1Id], references: [id])
  user2Id   String
  user2     User     @relation("DirConvUser2", fields: [user2Id], references: [id])
  createdAt DateTime @default(now())
  messages  Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model Message {
  id             String              @id @default(cuid())
  senderId       String
  sender         User                @relation("MessageSender", fields: [senderId], references: [id])
  receiverId     String
  receiver       User                @relation("MessageReceiver", fields: [receiverId], references: [id])
  matchId        String?             // Eşleşme bazlı mesaj (opsiyonel)
  match          Match?              @relation(fields: [matchId], references: [id])
  conversationId String?             // Direkt mesaj (opsiyonel)
  conversation   DirectConversation? @relation(fields: [conversationId], references: [id])
  content        String
  read           Boolean             @default(false)
  createdAt      DateTime            @default(now())

  @@index([matchId])
  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId, read])
}

// ========== EĞİTMEN PROFİLİ ==========
model TrainerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  listingId       String?  @unique
  listing         Listing? @relation(fields: [listingId], references: [id])
  hourlyRate      Float?                          // Saatlik ücret (₺)
  gymName         String?                         // Çalıştığı salon
  gymAddress      String?
  certificates    String[] @default([])        // Sertifika URL'leri (Supabase Storage)
  isVerified      Boolean  @default(false)     // Admin onayı
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  specializations TrainerSpecialization[]

  @@index([userId])
}

// Eğitmenin branş + deneyim çiftleri (birden fazla olabilir)
model TrainerSpecialization {
  id        String         @id @default(cuid())
  profileId String
  profile   TrainerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sportName String         // Örn: "Futbol", "Fitness", "Yüzme"
  years     Int            @default(0)  // Deneyim yılı
  createdAt DateTime       @default(now())

  @@index([profileId])
  @@index([sportName])
}

// ========== OTP DOĞRULAMA ==========
model MatchOtp {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  userId    String                               // OTP'yi isteyen kullanıcı
  code      String                               // 6 haneli kod
  expiresAt DateTime                             // 15 dk sonra
  usedAt    DateTime?                            // Kullanıldıysa
  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([userId])
  @@index([code, expiresAt])
}

// ========== MEKAN PROFİLİ ==========
model VenueProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  businessName String                            // Tesis / Kurum adı
  address      String?                           // Tam adres
  description  String?                           // Açıklama
  phone        String?                           // İletişim
  website      String?                           // Web sitesi
  capacity     Int?                              // Toplam kişi kapasitesi
  sports       String[] @default([])             // Faaliyet gösterilen sporlar (hızlı filtre)
  equipment    String[] @default([])             // Mevcut spor malzemeleri
  amenities    String[] @default([])             // Tesis olanakları (kafeterya, sauna, otopark…)
  images       String[] @default([])             // Tesis görselleri
  logoUrl      String?                           // Logo / profil fotoğrafı
  openingHours String?                           // "09:00-22:00" formatı
  isVerified   Boolean  @default(false)          // Admin onayı
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facilities   VenueFacility[]

  @@index([userId])
}

// Tesis bünyesindeki alan/kort/saha bilgileri (spor başına)
model VenueFacility {
  id           String       @id @default(cuid())
  profileId    String
  profile      VenueProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sportName    String       // Örn: "Futbol", "Tenis"
  facilityType String       // "saha" | "kort" | "havuz" | "ring" | "salon"
  count        Int          @default(1)  // Kaç adet
  equipment    String[]     @default([]) // Bu spor için ekipman listesi
  createdAt    DateTime     @default(now())

  @@index([profileId])
  @@index([sportName])
}

// ========== SATILIK MALZEME DETAYI ==========
enum EquipmentCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

model EquipmentDetail {
  id          String             @id @default(cuid())
  listingId   String             @unique
  listing     Listing            @relation(fields: [listingId], references: [id])
  price       Float
  condition   EquipmentCondition @default(GOOD)
  images      String[] @default([])  // Görsel URL'leri (Supabase Storage)
  brand       String?
  model       String?
  isSold      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([listingId])
}

// ========== KULÜP ==========
model Club {
  id          String   @id @default(cuid())
  name        String
  creatorId   String?
  creator     User?    @relation("ClubCreator", fields: [creatorId], references: [id])
  sportId     String?
  sport       Sport?   @relation(fields: [sportId], references: [id])
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])
  website     String?
  logoUrl     String?
  description String?
  isPrivate   Boolean  @default(false)   // true = katılım onay gerektirir
  createdAt   DateTime @default(now())

  members     UserClubMembership[]
  posts       Post[]

  @@unique([name, cityId])
  @@index([sportId])
  @@index([cityId])
  @@index([creatorId])
}

model UserClubMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  role      String   @default("MEMBER")   // "MEMBER" | "CAPTAIN"
  status    String   @default("APPROVED") // "PENDING" | "APPROVED" | "REJECTED"
  joinedAt  DateTime @default(now())

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
  @@index([status])
}

// ========== GRUP ==========
enum GroupMemberRole {
  MEMBER
  ADMIN
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  sportId     String?
  sport       Sport?   @relation(fields: [sportId], references: [id])
  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])
  creatorId   String
  creator     User     @relation("GroupCreator", fields: [creatorId], references: [id])
  isPublic    Boolean  @default(true)
  avatarUrl   String?
  createdAt   DateTime @default(now())

  members  GroupMembership[]
  listings Listing[]
  posts    Post[]

  @@unique([name, cityId])
  @@index([sportId])
  @@index([cityId])
  @@index([creatorId])
}

model GroupMembership {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id])
  groupId  String
  group    Group           @relation(fields: [groupId], references: [id])
  role     GroupMemberRole @default(MEMBER)
  status   String          @default("APPROVED") // "PENDING" | "APPROVED" | "REJECTED"
  joinedAt DateTime        @default(now())

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
}

// ========== DOĞRUDAN TEKLIF ==========
enum DirectChallengeStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model DirectChallenge {
  id               String                 @id @default(cuid())
  challengerId     String
  challenger       User                   @relation("ChallengesSent", fields: [challengerId], references: [id])
  targetId         String
  target           User                   @relation("ChallengesReceived", fields: [targetId], references: [id])
  sportId          String
  sport            Sport                  @relation(fields: [sportId], references: [id])
  message          String?
  proposedDateTime DateTime?
  districtId       String?
  district         District?              @relation(fields: [districtId], references: [id])
  challengeType    String                 @default("RIVAL") // "RIVAL" | "PARTNER"
  status           DirectChallengeStatus  @default(PENDING)
  expiresAt        DateTime               // 48 saat sonra otomatik EXPIRED
  createdAt        DateTime               @default(now())

  @@index([challengerId])
  @@index([targetId])
  @@index([status])
  @@index([expiresAt])
}

// ========== DOĞRUDAN TEKLIF SONU ==========
model Post {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  content   String?                          // Yazı içeriği
  images    String[]  @default([])           // Görsel URL'leri (Supabase Storage)
  groupId   String?                          // Grup gönderisi
  group     Group?    @relation(fields: [groupId], references: [id])
  clubId    String?                          // Kulüb gönderisi
  club      Club?     @relation(fields: [clubId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  likes     PostLike[]
  comments  PostComment[]

  @@index([userId])
  @@index([createdAt])
  @@index([groupId])
  @@index([clubId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reaction  String   @default("like")       // "like" | "fire" | "muscle" | "clap" | "goal"
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

// ========== STORY / HİKAYE ==========

enum StoryType {
  MEDIA        // klasik fotoğraf/video
  MATCH        // ilan ile bağlantılı
  RESULT       // maç sonucu paylaşımı
  ACHIEVEMENT  // gamification rozeti
}

model Story {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           StoryType   @default(MEDIA)
  mediaUrl       String?                         // fotoğraf veya video URL
  mediaType      String?                         // "image" | "video"
  caption        String?     @db.VarChar(300)
  // Contextual bağlantılar (nullable)
  linkedListingId String?
  linkedMatchId   String?
  linkedMatchResult String?                      // "3-1", "Kazandım" vb.
  linkedBadgeKey  String?                        // gamification badge key
  // Zamanlama
  expiresAt      DateTime                        // createdAt + 24h
  createdAt      DateTime    @default(now())
  // İlişkiler
  views          StoryView[]
  highlights     StoryHighlightItem[]

  @@index([userId])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  viewedAt  DateTime @default(now())

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}

// Highlight = kullanıcının öne çıkardığı hikaye koleksiyonu
model StoryHighlight {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String               @db.VarChar(50)
  coverUrl  String?              // highlight kapak resmi
  order     Int                  @default(0)
  createdAt DateTime             @default(now())
  items     StoryHighlightItem[]

  @@index([userId])
}

model StoryHighlightItem {
  id          String         @id @default(cuid())
  highlightId String
  highlight   StoryHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  storyId     String
  story       Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)
  addedAt     DateTime       @default(now())

  @@unique([highlightId, storyId])
  @@index([highlightId])
}

// ========== MEKAN CACHE (Google Places) ==========
model VenueCache {
  id          String   @id @default(cuid())
  query       String                    // "İstanbul-Kadıköy-futbol"
  lat         Float
  lng         Float
  placesJson  String                    // Google Places API yanıtı JSON
  createdAt   DateTime @default(now())

  @@unique([query])
  @@index([query])
}

// ========== WEB PUSH ABONELİĞİ ==========
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique          // Push endpoint URL
  p256dh    String                    // Şifreleme anahtarı
  auth      String                    // Auth token
  createdAt DateTime @default(now())

  @@index([userId])
}

// ========== TOPLULUK (Group + Club birleşimi) ==========
enum CommunityType {
  GROUP  // Spor grubu (herkes katılabilir / onay gerektirir)
  CLUB   // Spor kulübü (kurumsal, kaptan onaylı)
  TEAM   // Takım (küçük, maç odaklı)
}

enum CommunityRole {
  MEMBER
  ADMIN
}

model Community {
  id          String        @id @default(cuid())
  type        CommunityType @default(GROUP)
  name        String
  description String?
  avatarUrl   String?
  website     String?                        // Kulüpler için
  isPrivate   Boolean       @default(false)  // true = katılım onay gerektirir
  sportId     String?
  sport       Sport?        @relation(fields: [sportId], references: [id])
  cityId      String?
  city        City?         @relation(fields: [cityId], references: [id])
  creatorId   String
  creator     User          @relation("CommunityCreator", fields: [creatorId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     CommunityMembership[]

  @@unique([name, cityId, type])
  @@index([sportId])
  @@index([cityId])
  @@index([creatorId])
  @@index([type])
}

// ──────────────── TURNUVA ────────────────

enum TournamentStatus {
  DRAFT       // Yayınlanmadı
  OPEN        // Kayıt açık
  ONGOING     // Devam ediyor
  COMPLETED   // Tamamlandı
  CANCELLED   // İptal edildi
}

enum TournamentFormat {
  SINGLE_ELIMINATION // Tek eleme
  ROUND_ROBIN        // Herkes herkesle
  SWISS              // İsviçre sistemi
}

enum ParticipantStatus {
  PENDING   // Onay bekliyor
  APPROVED  // Onaylandı
  REJECTED  // Reddedildi
  WITHDRAWN // Ayrıldı
}

model Tournament {
  id           String             @id @default(cuid())
  creatorId    String
  creator      User               @relation("CreatedTournaments", fields: [creatorId], references: [id])
  title        String
  description  String?            @db.Text
  sportId      String?
  sport        Sport?             @relation(fields: [sportId], references: [id])
  format       TournamentFormat   @default(SINGLE_ELIMINATION)
  status       TournamentStatus   @default(DRAFT)
  maxParticipants Int             @default(16)
  prizeInfo    String?            @db.Text
  startsAt     DateTime?
  endsAt       DateTime?
  location     String?
  venueId      String?
  venue        Venue?             @relation(fields: [venueId], references: [id])
  coverImage   String?
  isPublic     Boolean            @default(true)
  participants TournamentParticipant[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([creatorId])
  @@index([sportId])
  @@index([status])
  @@index([startsAt])
}

model TournamentParticipant {
  id           String            @id @default(cuid())
  tournamentId String
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User              @relation("TournamentParticipations", fields: [userId], references: [id])
  status       ParticipantStatus @default(PENDING)
  rank         Int?              // Final sıralama
  joinedAt     DateTime          @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model CommunityMembership {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  communityId String
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  role        CommunityRole @default(MEMBER)
  status      String        @default("APPROVED") // "PENDING" | "APPROVED" | "REJECTED"
  joinedAt    DateTime      @default(now())

  @@unique([userId, communityId])
  @@index([userId])
  @@index([communityId])
  @@index([status])
}

// ========== ENGELLEME ==========
enum BlockType {
  BLOCK     // Tam engel: profil, mesaj, ilan görünmez
  RESTRICT  // Kısıtla: kullanıcıyı görür ama etkileşim sınırlı
}

model UserBlock {
  id          String    @id @default(cuid())
  blockerId   String
  blocker     User      @relation("BlockSource", fields: [blockerId], references: [id])
  blockedId   String
  blocked     User      @relation("BlockTarget", fields: [blockedId], references: [id])
  type        BlockType @default(BLOCK)
  createdAt   DateTime  @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ========== ŞİKAYET ==========
enum ReportReason {
  SPAM
  HARASSMENT
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  SCAM
  OTHER
}

model UserReport {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("ReportSource", fields: [reporterId], references: [id])
  reportedId  String
  reported    User         @relation("ReportTarget", fields: [reportedId], references: [id])
  reason      ReportReason
  description String?      @db.Text
  resolved    Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([reporterId])
  @@index([reportedId])
  @@index([resolved])
}
