generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ========== KULLANICI ==========
enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String?
  phone        String?
  avatarUrl    String?
  coverUrl     String?   // Kapak fotoğrafı
  bio          String?
  cityId       String?
  city         City?     @relation(fields: [cityId], references: [id])
  districtId   String?
  district     District? @relation(fields: [districtId], references: [id])
  gender       Gender?                          // Cinsiyet
  birthDate    DateTime?                        // Doğum Tarihi
  noShowCount  Int       @default(0)            // Gelmedi sayacı
  warnCount    Int       @default(0)            // Uyarı sayacı
  isBanned     Boolean   @default(false)        // Geçici kısıtlama
  // Onboarding tercihleri
  preferredTime  String?                        // "morning" | "evening" | "anytime"
  preferredStyle String?                        // "competitive" | "casual" | "both"
  onboardingDone Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  listings          Listing[]
  responses         Response[]
  matches1          Match[]         @relation("MatchUser1")
  matches2          Match[]         @relation("MatchUser2")
  sports            Sport[]         @relation("UserSports")
  ratingsGiven      Rating[]        @relation("RatingGiver")
  ratingsReceived   Rating[]        @relation("RatingReceiver")
  notifications     Notification[]
  favorites         Favorite[]
  resetTokens       PasswordResetToken[]
  followers         Follow[]        @relation("FollowTarget")
  following         Follow[]        @relation("FollowSource")
  messagesSent      Message[]       @relation("MessageSender")
  messagesReceived  Message[]       @relation("MessageReceiver")
  noShowsReported   NoShowReport[]  @relation("NoShowReporter")
  noShowsReceived   NoShowReport[]  @relation("NoShowReceived")
  trainerProfile    TrainerProfile?
  posts             Post[]
  postLikes         PostLike[]
  postComments      PostComment[]
}

// ========== SPOR ==========
model Sport {
  id       String    @id @default(cuid())
  name     String    @unique
  icon     String?
  listings Listing[]
  venues   Venue[]
  users    User[]    @relation("UserSports")
}

// ========== KONUM ==========
model Country {
  id     String @id @default(cuid())
  name   String @unique
  code   String @unique
  cities City[]
}

model City {
  id        String     @id @default(cuid())
  name      String
  countryId String
  country   Country    @relation(fields: [countryId], references: [id])
  districts District[]
  users     User[]

  @@unique([name, countryId])
}

model District {
  id       String    @id @default(cuid())
  name     String
  cityId   String
  city     City      @relation(fields: [cityId], references: [id])
  venues   Venue[]
  listings Listing[]
  users    User[]

  @@unique([name, cityId])
}

// ========== MEKAN ==========
model Venue {
  id         String    @id @default(cuid())
  name       String
  address    String?
  districtId String
  district   District  @relation(fields: [districtId], references: [id])
  sportId    String?
  sport      Sport?    @relation(fields: [sportId], references: [id])
  listings   Listing[]

  @@unique([name, districtId])
}

// ========== İLAN ==========
enum ListingType {
  RIVAL
  PARTNER
  TRAINER    // Eğitmen ilanı
  EQUIPMENT  // Satılık spor malzemesi
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ListingStatus {
  OPEN
  CLOSED
  MATCHED
  EXPIRED
}

enum AllowedGender {
  ANY
  FEMALE_ONLY
  MALE_ONLY
}

model Listing {
  id              String        @id @default(cuid())
  type            ListingType
  sportId         String
  sport           Sport         @relation(fields: [sportId], references: [id])
  districtId      String
  district        District      @relation(fields: [districtId], references: [id])
  venueId         String?
  venue           Venue?        @relation(fields: [venueId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  dateTime        DateTime
  level           Level
  description     String?
  status          ListingStatus @default(OPEN)
  maxParticipants Int           @default(2)       // 2=1v1, 3+=grup
  allowedGender   AllowedGender @default(ANY)     // Cinsiyet kısıtı
  isQuick         Boolean       @default(false)   // "Hadi Gel" hızlı ilan
  expiresAt       DateTime?                       // Hızlı ilan bitiş zamanı
  isRecurring     Boolean       @default(false)   // Tekrarlayan etkinlik
  recurringDays   String?                         // "MON,WED,FRI" formatında
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  responses   Response[]
  match       Match?
  favorites   Favorite[]
  noShows         NoShowReport[]
  trainerProfile  TrainerProfile?
  equipmentDetail EquipmentDetail?

  @@index([status, dateTime])
  @@index([sportId])
  @@index([districtId])
  @@index([userId])
  @@index([status, sportId, dateTime])
  @@index([expiresAt])
}

// ========== KARŞILIK ==========
enum ResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Response {
  id        String         @id @default(cuid())
  listingId String
  listing   Listing        @relation(fields: [listingId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  message   String?
  status    ResponseStatus @default(PENDING)
  createdAt DateTime       @default(now())

  match Match?

  @@unique([listingId, userId])
  @@index([userId])
  @@index([status])
}

// ========== EŞLEŞME ==========
model Match {
  id         String   @id @default(cuid())
  listingId  String   @unique
  listing    Listing  @relation(fields: [listingId], references: [id])
  responseId String   @unique
  response   Response @relation(fields: [responseId], references: [id])
  user1Id    String
  user1      User     @relation("MatchUser1", fields: [user1Id], references: [id])
  user2Id    String
  user2      User     @relation("MatchUser2", fields: [user2Id], references: [id])
  createdAt  DateTime @default(now())

  ratings      Rating[]
  messages     Message[]
  noShowReports NoShowReport[]

  @@index([user1Id])
  @@index([user2Id])
}

// ========== DEĞERLENDİRME ==========
model Rating {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id])
  ratedById   String
  ratedBy     User     @relation("RatingGiver", fields: [ratedById], references: [id])
  ratedUserId String
  ratedUser   User     @relation("RatingReceiver", fields: [ratedUserId], references: [id])
  score       Int      // 1-5
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([matchId, ratedById])
  @@index([ratedUserId])
}

// ========== BİLDİRİM ==========
enum NotificationType {
  NEW_RESPONSE
  RESPONSE_ACCEPTED
  RESPONSE_REJECTED
  NEW_MATCH
  NEW_RATING
  NEW_FOLLOWER
  NEW_MESSAGE
  NO_SHOW_WARNING
  NEW_POST_LIKE      // Gönderi beğenildi
  NEW_POST_COMMENT   // Gönderiye yorum yapıldı
  TRAINER_VERIFIED   // Eğitmen profili onaylandı
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ========== FAVORİLER ==========
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// ========== ŞİFRE SIFIRLAMA ==========
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  user      User     @relation(fields: [email], references: [email])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ========== TAKİP ==========
model Follow {
  id          String   @id @default(cuid())
  followerId  String   // takip eden
  follower    User     @relation("FollowSource", fields: [followerId], references: [id])
  followingId String   // takip edilen
  following   User     @relation("FollowTarget", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ========== NO-SHOW RAPORU ==========
model NoShowReport {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id])
  reporterId String
  reporter   User     @relation("NoShowReporter", fields: [reporterId], references: [id])
  reportedId String
  reported   User     @relation("NoShowReceived", fields: [reportedId], references: [id])
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([matchId, reporterId])
  @@index([reportedId])
  @@index([matchId])
}

// ========== MESAJLAŞMA ==========
model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  matchId    String   // Sadece eşleşmiş kullanıcılar mesajlaşabilir
  match      Match    @relation(fields: [matchId], references: [id])
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([matchId])
  @@index([senderId])
  @@index([receiverId, read])
}

// ========== EĞİTMEN PROFİLİ ==========
model TrainerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  listingId       String?  @unique
  listing         Listing? @relation(fields: [listingId], references: [id])
  hourlyRate      Float?                       // Saatlik ücret
  experience      Int?                         // Deneyim yılı
  specialization  String?                      // "Çocuklar" | "Yetişkinler" | "Her Yaş"
  gymName         String?                      // Çalıştığı salon
  gymAddress      String?
  certificates    String[] @default([])        // Sertifika URL'leri (Supabase Storage)
  isVerified      Boolean  @default(false)     // Admin onayı
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// ========== SATILIK MALZEME DETAYI ==========
enum EquipmentCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

model EquipmentDetail {
  id          String             @id @default(cuid())
  listingId   String             @unique
  listing     Listing            @relation(fields: [listingId], references: [id])
  price       Float
  condition   EquipmentCondition @default(GOOD)
  images      String[] @default([])  // Görsel URL'leri (Supabase Storage)
  brand       String?
  model       String?
  isSold      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([listingId])
}

// ========== SOSYAL PAYLAŞIMLAR ==========
model Post {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  content   String?                          // Yazı içeriği
  images    String[]  @default([])           // Görsel URL'leri (Supabase Storage)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  likes     PostLike[]
  comments  PostComment[]

  @@index([userId])
  @@index([createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

// ========== MEKAN CACHE (Google Places) ==========
model VenueCache {
  id          String   @id @default(cuid())
  query       String                    // "İstanbul-Kadıköy-futbol"
  lat         Float
  lng         Float
  placesJson  String                    // Google Places API yanıtı JSON
  createdAt   DateTime @default(now())

  @@unique([query])
  @@index([query])
}
